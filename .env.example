# Public Supabase URL — exposed to the browser
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key

# Server-only — never expose to browser
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Site URL used in auth redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Comma-separated list of admin user UUIDs (gates /admin/* routes)
ADMIN_USER_IDS=

# Chat email notifications
EMAIL_PROVIDER=inbucket
EMAIL_FROM='Barter <notify@localhost>'
# RESEND_API_KEY=
NOTIFY_TOKEN_SECRET=dev-only-do-not-use-in-prod-must-be-at-least-32-chars
